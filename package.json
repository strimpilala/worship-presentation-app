{
  "name": "p-worship",
  "version": "1.0.0",
  "description": "EasyWorship-style scripture presentation app with voice search and multi-version display",
  "main": "main.js",
  "author": "Jonathan",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build-db": "node db/build-db.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "@xenova/transformers": "^2.17.2"
  },
  "dependencies": {
    "better-sqlite3": "^11.1.2",
    "express": "^4.19.2",
    "ws": "^8.18.0",
    "cors": "^2.8.5",
    "qrcode": "^1.5.4",
    "axios": "^1.7.2"
  },
  "build": {
    "appId": "com.jonathan.pworship",
    "productName": "P Worship",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "ndi.js",
      "state.js",
      "src/**/*",
      "server/**/*",
      "db/**/*",
      "!db/source-bible.db",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
